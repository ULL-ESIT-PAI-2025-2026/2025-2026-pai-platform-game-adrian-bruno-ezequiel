{
  "name": "Platform Game",
  "description": "Platform Game",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "index.js",
  "scripts": {
    "build": "tsc",
    "tsc:watch": "tsc -w",
    "push": "rm *~; git pull; git add . ; git commit -m 'Code improvement'; git push",
    "pull": "git pull",
    "test": "jest",
    "lint:ci": "eslint \"src/**/*.ts\"",
    "sonar": "npx eslint \"src/**/*.ts\" -f json -o eslint-report.json ; npx sonarqube-scanner",
    "dev:server": "node scripts/dev-server.js",
    "start": "tsc-watch -p tsconfig.json --onSuccess \"npm run dev:server\""
  },
  "keywords": [
    "PAI"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@exercism/babel-preset-typescript": "^0.1.0",
    "@exercism/eslint-config-typescript": "^0.4.1",
    "@types/express": "^4.17.17",
    "@types/node": "^18.19.130",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "babel-jest": "^27.5.1",
    "core-js": "^3.21.0",
    "eslint": "^8.57.1",
    "eslint-config-google": "^0.14.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-jsdoc": "^46.10.1",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "globals": "^17.5.0",
    "jest": "^29.4.3",
    "ts-node": "^10.0.0",
    "tsc-watch": "^6.0.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0"
  }
}
