{
  "name": "Platform Game",
  "description": "Platform Game",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc-watch",
    "build:watch": "tsc -w",
    "push": "rm *~; git pull; git add . ; git commit -m 'Code improvement'; git push",
    "pull": "git pull",
    "dev": "concurrently \"tsc\" \"node scripts/dev-server.js\"",
    "test": "jest",
    "lint": "eslint \"src/**/*.ts\"",
    "docs": "typedoc",
    "server": "node script/dev-server.js",
    "start": "tsc-watch -p tsconfig.json --onSuccess \"node script/dev-server.js\""
  },
  "keywords": [
    "PAI"
  ],
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mathjs": "^12.0.0"
  },
  "devDependencies": {
    "@exercism/babel-preset-typescript": "^0.1.0",
    "@exercism/eslint-config-typescript": "^0.4.1",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.0.0",
    "core-js": "^3.21.0",
    "eslint": "^8.33.0",
    "eslint-config-standard-with-typescript": "^34.0.0",
    "eslint-plugin-import": "^2.27.5",
    "eslint-plugin-n": "^15.6.1",
    "eslint-plugin-promise": "^6.1.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.0.0",
    "tsc-watch": "^6.0.0",
    "typedoc": "^0.25.0",
    "typescript": "^5.0.0"
  }
}
